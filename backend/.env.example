# Application
NODE_ENV=development
PORT=3000
API_VERSION=1.0.0

# Database (Postgres 16, Yandex Cloud MDB in prod)
DB_HOST=localhost
DB_PORT=5432
DB_USER=eduson
DB_PASSWORD=change_me_strong_password
DB_NAME=eduson_kids
DB_SSL=false

# Redis (Yandex Cloud MDB Redis 7 in prod)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_ACCESS_SECRET=change_me_64_chars_random_hex_string_here_for_access_token
JWT_REFRESH_SECRET=change_me_64_chars_random_hex_string_here_for_refresh_token
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=30d

# PII Encryption - AES-256-GCM (base64-encoded 32-byte key)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# In prod: fetched from YC Lockbox secret
PII_KEY=REPLACE_WITH_BASE64_32_BYTE_KEY

# CORS whitelist (comma-separated)
CORS_WHITELIST=http://localhost:5173,http://localhost:3001

# CSRF
CSRF_SECRET=change_me_csrf_secret_32_chars_min

# YuKassa (billing)
YUKASSA_SHOP_ID=
YUKASSA_SECRET_KEY=
YUKASSA_WEBHOOK_HMAC_SECRET=

# School codes (comma-separated, for teacher login)
# In prod: stored in DB, this is just for MVP seed
SCHOOL_CODES=DEMO-2024

# Throttle (requests per window)
THROTTLE_LOGIN_LIMIT=5
THROTTLE_LOGIN_TTL=900000
THROTTLE_GLOBAL_LIMIT=100
THROTTLE_GLOBAL_TTL=60000

# Audit log retention (days)
AUDIT_LOG_RETENTION_DAYS=730

