# Шаблон для android/keystore.properties (НЕ ЗАЛИВАТЬ В GIT).
# Скопируй в keystore.properties и заполни реальными значениями.
#
# 1. Сгенерируй keystore (один раз, потом хранить вечно):
#    keytool -genkey -v -keystore eduson-kids-release.keystore \
#            -alias eduson-kids -keyalg RSA -keysize 2048 -validity 10000
#
# 2. Положи .keystore в android/app/ (gitignore уже игнорирует *.keystore).
#
# 3. Заполни эти 4 переменных:
storeFile=eduson-kids-release.keystore
storePassword=ЗАМЕНИ
keyAlias=eduson-kids
keyPassword=ЗАМЕНИ
